---
interface Props {
	title: string;
	description: string;
	keywords: string;
	canonicalPath: string;
	ogTitle: string;
	ogDescription: string;
	ogImage: string;
	lang?: string;
}

const {
	title,
	description,
	keywords,
	canonicalPath,
	ogTitle,
	ogDescription,
	ogImage,
	lang = 'en',
} = Astro.props;

const site = Astro.site?.toString() ?? 'https://arnaudhervy.com';
const canonicalUrl = new URL(canonicalPath, site).toString();
const imageUrl = new URL(ogImage, site).toString();
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="description" content={description} />
		<meta name="keywords" content={keywords} />
		<meta name="robots" content="noindex, follow" />
		<meta name="author" content="Arnaud Hervy" />

		<link rel="canonical" href={canonicalUrl} />

		<meta property="og:title" content={ogTitle} />
		<meta property="og:description" content={ogDescription} />
		<meta property="og:image" content={imageUrl} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalUrl} />
		<meta name="twitter:card" content="summary_large_image" />

		<title>{title}</title>
	</head>

	<body>
		<header>
			<nav>
				<a href={site}>Back to arnaudhervy.com</a>
			</nav>
		</header>

		<main id="main-content">
			<slot />
		</main>
	</body>
</html>

<style is:global>
	body {
		font-family:
			system-ui,
			-apple-system,
			BlinkMacSystemFont,
			'Segoe UI',
			Roboto,
			Oxygen,
			Ubuntu,
			Cantarell,
			'Open Sans',
			'Helvetica Neue',
			sans-serif;
		margin: 20px;
		background-color: #f8fafc;
		color: #475569;
	}

	main {
		background-color: #ffffff;
		padding: 20px;
		border-radius: 8px;
		border: 1px solid #cbd5e1;
		box-shadow: 0 1px 2px rgba(17, 24, 39, 0.08);
		max-width: 800px;
		margin: 0 auto;
		margin-bottom: 20px;
	}

	h1,
	h2,
	h3 {
		color: #1d4ed8;
		margin-top: 20px;
	}

	ul,
	ol {
		margin-bottom: 10px;
	}

	li {
		margin-bottom: 5px;
	}

	img {
		width: 100%;
		height: auto;
		display: block;
	}

	.alert {
		padding: 10px;
		margin-bottom: 15px;
		border-radius: 5px;
	}

	.important {
		border: 1px solid #1d4ed8;
		font-weight: bold;
	}

	.warning {
		border: 1px solid #b91c1c;
		font-weight: bold;
	}
</style>
