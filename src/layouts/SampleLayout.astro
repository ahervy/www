---
import '../styles/global.css';

interface Props {
	title: string;
	description: string;
	keywords: string;
	canonicalPath: string;
	backHref: string;
	ogTitle: string;
	ogDescription: string;
	ogImage: string;
	lang?: string;
}

const {
	title,
	description,
	keywords,
	canonicalPath,
	backHref,
	ogTitle,
	ogDescription,
	ogImage,
	lang = 'en',
} = Astro.props;

const site = Astro.site?.toString() ?? 'https://arnaudhervy.com';
const canonicalUrl = new URL(canonicalPath, site).toString();
const imageUrl = new URL(ogImage, site).toString();
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="description" content={description} />
		<meta name="keywords" content={keywords} />
		<meta name="robots" content="noindex, follow" />
		<meta name="author" content="Arnaud Hervy" />

		<link rel="canonical" href={canonicalUrl} />

		<meta property="og:title" content={ogTitle} />
		<meta property="og:description" content={ogDescription} />
		<meta property="og:image" content={imageUrl} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalUrl} />
		<meta name="twitter:card" content="summary_large_image" />

		<title>{title}</title>
	</head>

	<body class="sample-page">
		<header class="sample-header">
			<nav class="sample-nav" aria-label="Sample page navigation">
				<a class="sample-back-link" href={backHref}>← Back to case study</a>
			</nav>
		</header>

		<main class="sample-document" id="main-content">
			<slot />
		</main>
	</body>
</html>

<style is:global>
	.sample-page {
		color-scheme: light;
		min-height: 100vh;
		margin: 0;
		padding: var(--space-5);
		background-color: var(--color-background);
		color: var(--color-muted);
		font-family: var(--font-body);
	}

	.sample-header {
		max-width: 50rem;
		margin: 0 auto var(--space-4);
	}

	.sample-nav {
		display: flex;
	}

	.sample-back-link {
		display: inline-flex;
		align-items: center;
		gap: var(--space-2);
		color: var(--link-color);
		font-size: var(--text-base);
		font-weight: 600;
		text-decoration: underline;
		text-decoration-color: currentColor;
		text-underline-offset: var(--space-1);
		transition: color var(--theme-transition);
	}

	.sample-back-link:hover,
	.sample-back-link:focus {
		color: var(--accent-dark);
	}

	.sample-page a:focus-visible {
		outline: 2px solid var(--accent-regular);
		outline-offset: 3px;
		border-radius: var(--radius-sm);
	}

	.sample-document {
		max-width: 50rem;
		margin: 0 auto var(--space-5);
		padding: var(--space-5);
		background-color: var(--surface-card-background);
		border: var(--surface-card-border);
		border-radius: var(--radius-lg);
		box-shadow: var(--surface-card-shadow);
	}

	.sample-document h1,
	.sample-document h2,
	.sample-document h3 {
		color: var(--accent-regular);
		line-height: 1.2;
		margin: var(--space-5) 0 var(--space-2);
		font-family: var(--font-body);
		font-weight: 700;
	}

	.sample-document h1:first-child,
	.sample-document h2:first-child,
	.sample-document h3:first-child {
		margin-top: 0;
	}

	.sample-document h1 {
		font-size: var(--text-3xl);
	}

	.sample-document h2 {
		font-size: var(--text-2xl);
	}

	.sample-document h3 {
		font-size: var(--text-xl);
	}

	.sample-document p,
	.sample-document ul,
	.sample-document ol {
		margin-bottom: var(--space-3);
	}

	.sample-document ul,
	.sample-document ol {
		padding-left: var(--space-5);
	}

	.sample-document li {
		margin-bottom: var(--space-2);
	}

	.sample-document strong {
		color: var(--color-heading);
		font-weight: 700;
	}

	.sample-document a {
		color: var(--link-color);
		text-underline-offset: var(--space-1);
		transition: color var(--theme-transition);
	}

	.sample-document a:hover,
	.sample-document a:focus {
		color: var(--accent-dark);
	}

	.sample-document img {
		width: 100%;
		height: auto;
		display: block;
		border-radius: var(--radius-md);
	}

	.sample-document .alert {
		padding: var(--space-3);
		margin-bottom: var(--space-4);
		border: var(--surface-card-border);
		border-radius: var(--radius-md);
	}

	.sample-document .important {
		border-color: var(--accent-regular);
		font-weight: 700;
	}

	.sample-document .warning {
		border-color: var(--color-danger);
		color: var(--color-text);
		font-weight: 700;
	}

	@media (min-width: 50em) {
		.sample-page {
			padding: var(--space-8);
		}

		.sample-document {
			padding: var(--space-8);
		}
	}
</style>
