---
import { type CollectionEntry, getCollection, render } from 'astro:content';

import BaseLayout from '../../layouts/BaseLayout.astro';
import ContactCTA from '../../components/ContactCTA.astro';
import Icon from '../../components/Icon.astro';
import CallToAction from '../../components/CallToAction.astro';

interface Props {
	entry: CollectionEntry<'portfolio'>;
}

type DetailItem =
	| { label: string; type: 'text'; value: string | undefined }
	| { label: string; type: 'list' | 'tags'; value: string[] | undefined };

export async function getStaticPaths() {
	const portfolio = await getCollection('portfolio');
	return portfolio.map((entry) => ({
		params: { slug: entry.id },
		props: { entry },
	}));
}

export const prerender = true;

const { entry } = Astro.props;
const { Content } = await render(entry);
const site = Astro.site?.toString() ?? 'https://arnaudhervy.com';
const pageUrl = new URL(`/portfolio/${entry.id}/`, site).toString();
const imageUrl = entry.data.img ? new URL(entry.data.img, site).toString() : undefined;
const personId = new URL('/#arnaud-hervy', site).toString();
const sampleHref = entry.data.sample_url ?? entry.data.sample_path;
const jsonLdDescription = (entry.data.meta_description ?? entry.data.description)
	.replace(/\s+/g, ' ')
	.trim();

const overviewItems: DetailItem[] = [
	{ label: 'Audience', type: 'text', value: entry.data.audience },
	{ label: 'Role', type: 'text', value: entry.data.role },
	{ label: 'Deliverables', type: 'list', value: entry.data.deliverables },
	{ label: 'Tools', type: 'list', value: entry.data.tools },
	{ label: 'Constraints', type: 'list', value: entry.data.constraints },
	{ label: 'Outcomes', type: 'list', value: entry.data.outcomes },
	{ label: 'Tags', type: 'tags', value: entry.data.tags },
];

const detailItems = overviewItems.filter((item) => {
	if (Array.isArray(item.value)) {
		return item.value.length > 0;
	}

	return Boolean(item.value);
});

const jsonLd = {
	'@context': 'https://schema.org',
	'@type': 'CreativeWork',
	headline: entry.data.title,
	description: jsonLdDescription,
	image: imageUrl,
	author: {
		'@type': 'Person',
		'@id': personId,
	},
	url: pageUrl,
	about: entry.data.tags,
};
---

<BaseLayout
	title={`${entry.data.title} | Arnaud Hervy`}
	description={entry.data.meta_description}
	ogType="article"
	ogImage={imageUrl}
>
	<div class="stack gap-10 lg:gap-20 project-stack">
		<main class="stack gap-8 lg:gap-20" id="main-content" tabindex="-1">
			<div class="wrapper">
				<header class="hero hero--no-image">
					<div class="stack gap-4 lg:gap-6">
						<a class="back-link" href="/portfolio/">
							<Icon icon="arrow-left" /> Case studies
						</a>
						<h1 class="hero-title">{entry.data.title}</h1>
						<p class="content">{entry.data.description}</p>
						<div class="hero-buttons">
							{
								sampleHref ? (
									<CallToAction
										href={sampleHref}
										target={entry.data.sample_url ? '_blank' : undefined}
										rel={entry.data.sample_url ? 'noopener noreferrer' : undefined}
										class="sample-pill"
									>
										View sample
									</CallToAction>
								) : null
							}
						</div>
					</div>
				</header>
			</div>
			<div class="wrapper">
				<div class="narrow">
					{
						detailItems.length ? (
							<section class="content-card">
								<h2>Project overview</h2>
								<dl class="detail-list">
									{detailItems.map((item) => (
										<div>
											<dt>{item.label}</dt>
											<dd>
												{item.type === 'text' ? item.value : null}
												{item.type === 'list' && Array.isArray(item.value) ? (
													<ul class="detail-item-list">
														{item.value.map((value) => (
															<li>{value}</li>
														))}
													</ul>
												) : null}
												{item.type === 'tags' && Array.isArray(item.value) ? (
													<ul class="tag-list" aria-label="Project tags">
														{item.value.map((value) => (
															<li>{value}</li>
														))}
													</ul>
												) : null}
											</dd>
										</div>
									))}
								</dl>
							</section>
						) : null
					}
					<article class="content stack gap-4">
						<Content />
					</article>
				</div>
			</div>
		</main>
		<div class="project-cta">
			<ContactCTA />
		</div>
	</div>
	<script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
</BaseLayout>

<style>
	.narrow {
		max-width: 65ch;
		margin-inline: auto;
	}

	.content-card {
		background: var(--surface-card-background-muted);
		border-radius: var(--surface-card-radius);
		padding: var(--space-6);
		margin-bottom: var(--space-8);
	}

	.detail-list {
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--space-3);
		margin: var(--space-4) 0 0;
	}

	.detail-list div {
		display: grid;
		gap: var(--space-1);
	}

	.detail-list dt {
		font-weight: 600;
		color: var(--gray-100);
	}

	.detail-list dd {
		margin: 0;
		color: var(--gray-300);
	}

	.detail-item-list,
	.tag-list {
		margin: 0;
		padding: 0;
	}

	.detail-item-list {
		display: grid;
		gap: var(--space-1);
		padding-left: var(--space-5);
	}

	.tag-list {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-2);
		list-style: none;
	}

	.tag-list li {
		display: inline-flex;
		padding: 0.125rem var(--space-2);
		color: var(--accent-regular);
		background: var(--surface-card-background);
		border: var(--surface-card-border);
		border-radius: var(--radius-pill);
		font-size: var(--text-sm);
		font-weight: 600;
	}

	.project-cta {
		margin-top: var(--space-6);
	}

	@media (min-width: 50em) {
		.project-cta {
			margin-top: var(--space-10);
		}
	}
</style>
